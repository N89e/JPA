# Configuration Serveur
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# CORS Configuration
# Autorisé les origines à accéder au serveur (séparées par des virgules)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5000

# Configuration Email
EMAIL_SERVICE=gmail
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-specific-password
OWNER_EMAIL=owner@example.com
EMAIL_LOGO_URL=http://localhost:5000/images/Logo_Portfolio.png
EMAIL_SIGNATURE_URL=http://localhost:5000/images/Nuno_ESTEVES-SIGNATURE.png
IMAGES_PATH=./frontend/src/assets/images

# Logging
# Niveaux: debug, info, warn, error
LOG_LEVEL=info
# Format: json ou text
LOG_FORMAT=json
# Écrire les logs dans un fichier (true/false)
LOG_TO_FILE=false

# Rate Limiting
# Fenêtre temporelle en millisecondes (900000 = 15 minutes)
RATE_LIMIT_WINDOW_MS=900000
# Nombre de requêtes par fenêtre pour la validation de contact
RATE_LIMIT_MAX_REQUESTS=5
# Taille maximale des requêtes
MAX_REQUEST_SIZE=10mb

# Sécurité
MAX_MESSAGE_LENGTH=5000
MAX_NAME_LENGTH=100
MAX_EMAIL_LENGTH=254
MAX_SUBJECT_LENGTH=200

# Production (utiliser pour OVH)
# NODE_ENV=production
# ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com
# LOG_LEVEL=info
# LOG_FORMAT=json
# LOG_TO_FILE=true
# EMAIL_LOGO_URL=https://your-domain.com/images/Logo_Portfolio.png
# EMAIL_SIGNATURE_URL=https://your-domain.com/images/Nuno_ESTEVES-SIGNATURE.png
