# ⚠️ PRODUCTION ENVIRONMENT VARIABLES
# Copy this file to .env.production and configure ALL values
# NEVER commit .env.production to git!
# Add to .gitignore: .env.production

# =============================================================================
# 🚀 NODE & SERVER CONFIGURATION
# =============================================================================
NODE_ENV=production
PORT=5000
HOST=0.0.0.0  # Listen on all interfaces (for Docker)

# =============================================================================
# 🌐 FRONTEND CONFIGURATION
# =============================================================================
# IMPORTANT: Must match your actual domain
FRONTEND_URL=https://yourdomain.com
# FRONTEND_URL=https://nuno-esteves.fr  # Example
# FRONTEND_URL=https://portfolio.example.com  # Example

# =============================================================================
# 📧 EMAIL CONFIGURATION
# =============================================================================
# ⚠️ Use App Password (not Gmail password) for Gmail:
# https://myaccount.google.com/apppasswords

EMAIL_SERVICE=gmail
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password-16-characters

# Where to send contact form notifications
EMAIL_TO=your-email@gmail.com

# Email retry configuration
EMAIL_RETRY_ATTEMPTS=3
EMAIL_RETRY_DELAY_MS=2000

# =============================================================================
# 🔒 SECURITY CONFIGURATION
# =============================================================================
# Rate limiting (contact form)
RATE_LIMIT_WINDOW_MS=900000    # 15 minutes
RATE_LIMIT_MAX_REQUESTS=5       # 5 requests per window

# CORS allowed origins (comma-separated)
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Session/JWT (if implementing authentication later)
# JWT_SECRET=your-super-secret-key-at-least-32-characters-long
# SESSION_SECRET=your-session-secret

# =============================================================================
# 💾 DATABASE CONFIGURATION (if using MongoDB/PostgreSQL)
# =============================================================================
# MongoDB Example:
# DATABASE_URL=mongodb+srv://username:password@cluster.mongodb.net/portfolio?retryWrites=true&w=majority

# PostgreSQL Example:
# DATABASE_URL=postgresql://username:password@postgres-host:5432/portfolio

# =============================================================================
# 📊 LOGGING & MONITORING
# =============================================================================
LOG_LEVEL=info                    # error, warn, info, debug
LOG_FORMAT=json                   # json or text
LOG_TO_FILE=true
LOG_FILE_PATH=/var/log/portfolio/app.log

# Sentry error tracking (optional)
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project

# =============================================================================
# 🎯 API CONFIGURATION
# =============================================================================
API_TIMEOUT=30000                 # Request timeout in ms
MAX_REQUEST_SIZE=10mb             # Max payload size

# =============================================================================
# ✅ INPUT VALIDATION LIMITS
# =============================================================================
MAX_NAME_LENGTH=100
MAX_EMAIL_LENGTH=254
MAX_SUBJECT_LENGTH=200
MAX_MESSAGE_LENGTH=5000

# =============================================================================
# 🔄 CACHE CONFIGURATION (if using Redis)
# =============================================================================
# REDIS_URL=redis://redis-host:6379/0
# REDIS_PASSWORD=your-redis-password
# CACHE_TTL=3600  # 1 hour

# =============================================================================
# 🏢 CLOUD PROVIDER SPECIFIC
# =============================================================================

# AWS (if using AWS Secrets Manager)
# AWS_REGION=eu-west-1
# AWS_SECRET_NAME=portfolio/production

# Heroku
# HEROKU_APP_NAME=your-app-name

# OVH/VPS
# SERVER_IP=192.0.2.1
# SERVER_DOMAIN=yourdomain.com

# =============================================================================
# 📝 NOTES FOR DEPLOYMENT
# =============================================================================
# 1. Generate app-specific password for Gmail:
#    https://myaccount.google.com/apppasswords
#
# 2. Update FRONTEND_URL with your actual domain
#
# 3. For Docker: docker-compose -f docker-compose.prod.yml --env-file .env.production up -d
#
# 4. For Heroku: heroku config:set KEY=VALUE
#
# 5. For AWS: Use AWS Secrets Manager instead of .env file
#
# 6. For OVH: Use PM2 ecosystem.config.js with env variables
#
# 7. Security checklist:
#    - [ ] FRONTEND_URL is HTTPS
#    - [ ] EMAIL_PASSWORD is app password (not real password)
#    - [ ] .env.production is in .gitignore
#    - [ ] All email errors are logged but not exposed
#    - [ ] RATE_LIMIT configured
#    - [ ] Health check working
#
# 8. Testing before production:
#    - [ ] Test contact form
#    - [ ] Test email sending
#    - [ ] Check CORS headers
#    - [ ] Verify rate limiting
#    - [ ] Load test API endpoints
#
# 9. Monitoring setup:
#    - [ ] Error tracking (Sentry)
#    - [ ] Performance monitoring (DataDog/New Relic)
#    - [ ] Log aggregation (ELK/Datadog)
#    - [ ] Uptime monitoring
#    - [ ] SSL certificate monitoring
